---
import { SITE, absoluteSiteUrl, withBase } from "@/config";
import "../styles/global.css";
import ThemeToggle from "@/components/ThemeToggle.astro";
import SearchButton from "@/components/SearchButton.astro";
import SearchModal from "@/components/SearchModal.astro";
import Logo from "@/components/Logo.astro";
import GitHubButton from "@/components/GitHubButton.astro";
import { serializeJsonLd } from "@/lib/schema";

interface Props {
  title?: string;
  description?: string;
  type?: "website" | "article";
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
  publishedTime?: string;
  tags?: string[];
  structuredData?: Record<string, unknown>;
}

const {
  title = SITE.defaultTitle,
  description = SITE.description,
  type = "website",
  canonicalPath = Astro.url.pathname,
  image = SITE.socialImage.path,
  imageAlt = SITE.socialImage.alt,
  publishedTime,
  tags = [],
  structuredData,
} = Astro.props;

const pageTitle = title.includes(SITE.name) ? title : `${title} | ${SITE.name}`;
const canonicalUrl = absoluteSiteUrl(canonicalPath, Astro.site!);
const socialImageUrl = absoluteSiteUrl(image, Astro.site!);
const keywords = [...SITE.keywords, ...tags].join(", ");
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Microsoft Foundry" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <meta name="base-url" content={import.meta.env.BASE_URL.replace(/\/$/, '')} />
    <meta property="og:site_name" content={SITE.formalName} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content={SITE.socialImage.width.toString()} />
    <meta property="og:image:height" content={SITE.socialImage.height.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    {structuredData && <script type="application/ld+json" set:html={serializeJsonLd(structuredData)} />}
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <!-- Theme initialization script - runs before page renders to prevent flicker -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (theme === 'high-contrast') {
          document.documentElement.classList.add('high-contrast');
        }
        // 'light' is default - no class needed
      })();
    </script>
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} RSS Feed`}
      href={absoluteSiteUrl("/rss.xml", Astro.site!)}
    />
    <!-- KaTeX CSS for math rendering -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous">
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-surface text-primary">
    <header data-pagefind-ignore class="site-header sticky top-0 z-50 backdrop-blur-sm border-b border-subtle" style="background-color: color-mix(in srgb, var(--neutral-bg-1) 80%, transparent);">
      <nav class="max-w-6xl mx-auto px-3 py-3 sm:px-4 sm:py-4 flex flex-wrap items-center justify-between gap-2 sm:gap-4">
        <a href={withBase("/")} class="flex items-center gap-2 text-lg sm:text-xl font-bold text-primary">
          <Logo size={28} />
          {SITE.name}
        </a>
        <div class="flex items-center gap-2 sm:gap-4">
          <SearchButton />
          <ThemeToggle />
          <a
            href={withBase("/rss.xml")}
            class="hc-hover inline-flex items-center justify-center rounded-md p-1.5 sm:p-2 text-secondary hover:text-primary hover:bg-surface-elevated transition-colors"
            title="RSS Feed"
            aria-label="RSS Feed"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/>
            </svg>
          </a>
          <GitHubButton />
        </div>
      </nav>
    </header>

    <main data-pagefind-body class="max-w-6xl mx-auto px-4 py-8">
      <slot />
    </main>

    <footer data-pagefind-ignore class="border-t border-subtle mt-16">
      <div class="max-w-6xl mx-auto px-4 py-8 text-center text-muted text-sm space-y-3">
        <p>Built with Astro • MIT License</p>
        <nav class="flex flex-wrap justify-center gap-x-4 gap-y-2" aria-label="Footer">
          <a class="hover:text-primary transition-colors" href={SITE.repositoryUrl}>GitHub</a>
          <a class="hover:text-primary transition-colors" href={`${SITE.repositoryUrl}/blob/main/LICENSE`}>License</a>
          <a class="hover:text-primary transition-colors" href={`${SITE.repositoryUrl}/blob/main/CODE_OF_CONDUCT.md`}>Code of Conduct</a>
          <a class="hover:text-primary transition-colors" href={`${SITE.repositoryUrl}/blob/main/SECURITY.md`}>Security</a>
          <a class="hover:text-primary transition-colors" href={`${SITE.repositoryUrl}/blob/main/SUPPORT.md`}>Support</a>
          <a class="hover:text-primary transition-colors" href="https://privacy.microsoft.com/privacystatement">Privacy</a>
          <a class="hover:text-primary transition-colors" href="https://www.microsoft.com/legal/terms-of-use">Terms of Use</a>
          <a class="hover:text-primary transition-colors" href="https://www.microsoft.com/legal/intellectualproperty/trademarks">Trademarks</a>
        </nav>
      </div>
    </footer>

    <SearchModal />

    <script>
      import { trackEvent, trackError } from "@/lib/telemetry";

      // Add copy buttons to all code blocks
      document.querySelectorAll('pre').forEach((pre) => {
        // Skip if already has a copy button
        if (pre.querySelector('.copy-btn')) return;
        
        // Create wrapper if needed
        const wrapper = document.createElement('div');
        wrapper.className = 'relative group code-block-wrapper';
        pre.parentNode?.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);
        
        // Create copy button
        const btn = document.createElement('button');
        const iconMarkup = '<svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>';
        btn.className = 'copy-btn absolute top-2 right-2 h-7 inline-flex items-center justify-center px-2 text-xs bg-transparent hover:bg-white/10 text-code rounded opacity-100 transition-colors cursor-pointer';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = iconMarkup;
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code')?.textContent || pre.textContent || '';
          try {
            await navigator.clipboard.writeText(code);
            trackEvent("CopyCodeBlock", {
              codeLength: code.length,
            });
            btn.setAttribute('aria-label', 'Copied');
            btn.textContent = 'Copied!';
            setTimeout(() => {
              btn.setAttribute('aria-label', 'Copy code');
              btn.innerHTML = iconMarkup;
            }, 2000);
          } catch (err) {
            trackError(err, { action: "CopyCodeBlock" });
          }
        });
        wrapper.appendChild(btn);
      });
    </script>

    <!-- Application Insights telemetry -->
    <script>
      import { initTelemetry } from "@/lib/telemetry";
      initTelemetry();
    </script>

    <!-- Twemoji for consistent emoji rendering across platforms -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@twemoji/api@latest/dist/twemoji.min.js" crossorigin="anonymous"></script>
    <script is:inline>
      // Parse emojis after page load
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof twemoji !== 'undefined') {
          twemoji.parse(document.body, {
            folder: 'svg',
            ext: '.svg',
            base: 'https://cdn.jsdelivr.net/gh/twitter/twemoji@latest/assets/'
          });
        }
      });
    </script>

    <!-- WebMCP: expose Forgebook tools to browser agents (W3C spec) and legacy WebMCP widget -->
    <script is:inline>
      (function () {
        var basePath = document.querySelector('meta[name="base-url"]')?.content || '/forgebook';

        // --- Shared tool definitions ---
        // Each tool works with both the W3C document.modelContext API and the
        // jasonjmcghee/WebMCP widget fallback. The execute callback receives
        // structured input and reuses existing client-side page state.

        var tools = [
          {
            name: 'list_recipes',
            title: 'List Forgebook Recipes',
            description: 'List Microsoft Foundry Forgebook recipes with title, description, tags, and URL. Works best from the homepage.',
            inputSchema: { type: "object", properties: {} },
            annotations: { readOnlyHint: true },
            execute: function () {
              var cards = document.querySelectorAll('[data-notebook-slug]');
              if (cards.length === 0) {
                return "No recipe cards found on this page. Navigate to the homepage first.";
              }
              var recipes = [];
              cards.forEach(function (card) {
                recipes.push({
                  slug: card.getAttribute('data-notebook-slug'),
                  title: card.getAttribute('data-notebook-title') || card.querySelector('h3, h2')?.textContent?.trim(),
                  description: card.getAttribute('data-notebook-description') || '',
                  tags: (card.getAttribute('data-notebook-tags') || '').split(',').filter(Boolean),
                  url: window.location.origin + basePath + '/notebook/' + card.getAttribute('data-notebook-slug') + '/'
                });
              });
              return JSON.stringify(recipes, null, 2);
            }
          },
          {
            name: 'search_recipes',
            title: 'Search Forgebook Recipes',
            description: 'Search Microsoft Foundry Forgebook recipes by keyword (matches title, description, tags). Works best from the homepage.',
            inputSchema: {
              type: "object",
              properties: {
                query: { type: "string", description: "Search keyword" }
              },
              required: ["query"]
            },
            annotations: { readOnlyHint: true },
            execute: function (input) {
              var q = (input.query || '').toLowerCase();
              var cards = document.querySelectorAll('[data-notebook-slug]');
              var results = [];
              cards.forEach(function (card) {
                var title = (card.getAttribute('data-notebook-title') || card.querySelector('h3, h2')?.textContent || '').toLowerCase();
                var desc = (card.getAttribute('data-notebook-description') || '').toLowerCase();
                var tags = (card.getAttribute('data-notebook-tags') || '').toLowerCase();
                if (title.includes(q) || desc.includes(q) || tags.includes(q)) {
                  results.push({
                    slug: card.getAttribute('data-notebook-slug'),
                    title: card.getAttribute('data-notebook-title') || card.querySelector('h3, h2')?.textContent?.trim(),
                    description: card.getAttribute('data-notebook-description') || '',
                    tags: (card.getAttribute('data-notebook-tags') || '').split(',').filter(Boolean),
                    url: window.location.origin + basePath + '/notebook/' + card.getAttribute('data-notebook-slug') + '/'
                  });
                }
              });
              return results.length > 0 ? JSON.stringify(results, null, 2) : 'No recipes matched "' + input.query + '".';
            }
          },
          {
            name: 'get_page_content',
            title: 'Read Current Page',
            description: 'Get the text content of the current Forgebook page (useful for reading a recipe).',
            inputSchema: { type: "object", properties: {} },
            annotations: { readOnlyHint: true },
            execute: function () {
              var article = document.querySelector('article') || document.querySelector('[data-pagefind-body]');
              if (!article) return "No article content found on this page.";
              var text = article.innerText || article.textContent || '';
              if (text.length > 12000) {
                text = text.substring(0, 12000) + '\n\n[... truncated — page has ' + text.length + ' characters total]';
              }
              return text;
            }
          },
          {
            name: 'navigate_to_recipe',
            title: 'Go to Recipe',
            description: 'Navigate the browser to a specific Forgebook recipe by slug.',
            inputSchema: {
              type: "object",
              properties: {
                slug: { type: "string", description: "The recipe slug, e.g. foundry-agent-part-1" }
              },
              required: ["slug"]
            },
            annotations: { readOnlyHint: false },
            execute: function (input) {
              var url = window.location.origin + basePath + '/notebook/' + input.slug + '/';
              window.location.href = url;
              return 'Navigating to ' + url;
            }
          },
          {
            name: 'get_current_page_info',
            title: 'Current Page Info',
            description: 'Get metadata about the current Forgebook page (URL, title, description, whether it is a recipe).',
            inputSchema: { type: "object", properties: {} },
            annotations: { readOnlyHint: true },
            execute: function () {
              return JSON.stringify({
                url: window.location.href,
                title: document.title,
                description: document.querySelector('meta[name="description"]')?.content || '',
                isRecipePage: !!document.querySelector('article .notebook-content'),
                recipeTitle: document.querySelector('article h1, [data-pagefind-meta="title"]')?.textContent?.trim() || null
              }, null, 2);
            }
          }
        ];

        function toToolResult(result) {
          if (result && typeof result === 'object' && Array.isArray(result.content)) {
            return result;
          }

          return {
            content: [
              {
                type: 'text',
                text: typeof result === 'string' ? result : JSON.stringify(result, null, 2)
              }
            ]
          };
        }

        function registerNativeTools(modelContext, label) {
          tools.forEach(function (t) {
            try {
              modelContext.registerTool({
                name: t.name,
                title: t.title,
                description: t.description,
                inputSchema: t.inputSchema,
                annotations: t.annotations,
                execute: async function (input) {
                  return toToolResult(await Promise.resolve(t.execute(input || {})));
                }
              });
            } catch (e) {
              console.warn('[WebMCP/' + label + '] Failed to register tool "' + t.name + '":', e);
            }
          });
        }

        // ---------------------------------------------------------------
        // W3C WebMCP (document.modelContext) — native browser agent API
        // Spec: https://webmachinelearning.github.io/webmcp/
        // ---------------------------------------------------------------
        if (typeof document !== 'undefined' && document.modelContext && typeof document.modelContext.registerTool === 'function') {
          registerNativeTools(document.modelContext, 'document.modelContext');
        } else if (typeof navigator !== 'undefined' && navigator.modelContext && typeof navigator.modelContext.registerTool === 'function') {
          // Compatibility fallback for older browser prototypes that exposed
          // WebMCP on navigator instead of document.
          registerNativeTools(navigator.modelContext, 'navigator.modelContext');
        }

        // ---------------------------------------------------------------
        // Legacy WebMCP widget (jasonjmcghee/WebMCP) — fallback for
        // environments without native browser agent support.
        // Loaded async; tools registered on script load.
        // ---------------------------------------------------------------
        window.__forgebook_tools = tools;
      })();
    </script>
    <script is:inline define:vars={{ webmcpSrc: withBase("/webmcp.js") }}>
      (function () {
        var s = document.createElement('script');
        s.src = webmcpSrc;
        s.onload = function () {
          if (typeof WebMCP === 'undefined' || !window.__forgebook_tools) return;
          var mcp = new WebMCP({
            color: '#6366f1',
            position: 'bottom-right',
            size: '28px',
            padding: '16px'
          });
          window.__forgebook_tools.forEach(function (t) {
            mcp.registerTool(
              t.name,
              t.description,
              t.inputSchema,
              function (args) {
                var result = t.execute(args || {});
                return toToolResult(result);
              }
            );
          });
        };
        document.head.appendChild(s);
      })();
    </script>
  </body>
</html>
