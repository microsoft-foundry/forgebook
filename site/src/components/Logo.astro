<style>
  /* Light mode: show color logo, hide others */
  .logo-light { display: block; }
  .logo-dark { display: none; }
  .logo-hc { display: none; }

  /* Dark mode: show white logo */
  :global(.dark) .logo-light { display: none; }
  :global(.dark) .logo-dark { display: block; }
  :global(.dark) .logo-hc { display: none; }

  /* High contrast mode: show outlined logo */
  :global(.high-contrast) .logo-light { display: none; }
  :global(.high-contrast) .logo-dark { display: none; }
  :global(.high-contrast) .logo-hc { display: block; }
</style>
