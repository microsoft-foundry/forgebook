---
interface Props {
  github: string;
  name: string;
  avatar: string;
  profileUrl: string;
}

const { github, name, avatar, profileUrl } = Astro.props;
---

<a
  href={profileUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
>
  <img
    src={avatar}
    alt={`${name}'s avatar`}
    class="w-10 h-10 rounded-full border-2 border-slate-200 dark:border-slate-700"
    loading="lazy"
  />
  <div>
    <div class="font-medium text-slate-900 dark:text-slate-100">{name}</div>
    <div class="text-sm text-slate-500">@{github}</div>
  </div>
</a>
