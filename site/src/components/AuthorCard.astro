---
interface Props {
  github: string;
  name: string;
  title?: string;
  avatar: string;
  profileUrl: string;
  githubUrl?: string;
  linkedinUrl?: string;
  xUrl?: string;
}

const { github, name, title, avatar, profileUrl, githubUrl, linkedinUrl, xUrl } = Astro.props;
const avatarHref = githubUrl || profileUrl;
const profileHref = profileUrl || githubUrl;
const hasSocial = Boolean(linkedinUrl || xUrl);
---
<div class="flex items-start justify-between gap-3 p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
  <div class="flex items-center gap-3 min-w-0">
    <a
      href={avatarHref}
      target="_blank"
      rel="noopener noreferrer"
      class="shrink-0"
      aria-label={`${name} on GitHub`}
    >
      <img
        src={avatar}
        alt={`${name}'s avatar`}
        onerror={`this.onerror=null;this.src='https://github.com/${github}.png?size=200';`}
        class="w-14 h-14 rounded-full border-2 border-slate-200 dark:border-slate-700"
        loading="lazy"
      />
    </a>
    <a
      href={profileHref}
      target="_blank"
      rel="noopener noreferrer"
      class="min-w-0"
      aria-label={`${name} profile`}
    >
      <div class="font-medium text-slate-900 dark:text-slate-100 truncate">{name}</div>
      {title && <div class="text-sm text-slate-500 truncate">{title}</div>}
      <div class="text-sm text-slate-500">@{github}</div>
    </a>
  </div>
  {hasSocial && (
    <div class="flex flex-col items-center gap-2 text-slate-500">
      {linkedinUrl && (
        <a
          href={linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-md p-1 hover:bg-slate-200 dark:hover:bg-slate-700"
          aria-label="LinkedIn"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d="M4.98 3.5C3.88 3.5 3 4.4 3 5.5s.88 2 1.98 2c1.09 0 1.98-.9 1.98-2s-.89-2-1.98-2zM3.5 8.98h2.96V21H3.5V8.98zM9.24 8.98h2.84v1.64h.04c.4-.76 1.38-1.56 2.84-1.56 3.04 0 3.6 2.05 3.6 4.71V21h-2.96v-5.5c0-1.31-.02-2.99-1.82-2.99-1.82 0-2.1 1.45-2.1 2.9V21H9.24V8.98z" />
          </svg>
        </a>
      )}
      {xUrl && (
        <a
          href={xUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-md p-1 hover:bg-slate-200 dark:hover:bg-slate-700"
          aria-label="X"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
            <path d="M18.9 2H22l-7.2 8.2L23 22h-6.4l-5-6.2L5.7 22H2.6l7.7-8.7L1 2h6.5l4.5 5.6L18.9 2zM17.8 20h1.8L6.3 3.9H4.4L17.8 20z" />
          </svg>
        </a>
      )}
    </div>
  )}
</div>
