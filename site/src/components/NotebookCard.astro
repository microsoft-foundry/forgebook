---
interface Author {
  github: string;
}

interface NotebookEntry {
  slug: string;
  path: string;
  title: string;
  description?: string;
  date?: string;
  authors: Author[];
  tags?: string[];
}

interface Props {
  notebook: NotebookEntry;
}

const { notebook } = Astro.props;
---

<a
  href={`/notebook/${notebook.slug}`}
  class="block p-6 bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 hover:border-blue-400 dark:hover:border-blue-500 hover:shadow-lg transition-all"
>
  <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-2">
    {notebook.title}
  </h3>
  {
    notebook.description && (
      <p class="text-slate-600 dark:text-slate-400 text-sm mb-4">
        {notebook.description}
      </p>
    )
  }
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      {
        notebook.authors.slice(0, 3).map((author) => (
          <img
            src={`https://github.com/${author.github}.png?size=40`}
            alt={author.github}
            class="w-6 h-6 rounded-full border border-slate-200 dark:border-slate-600"
          />
        ))
      }
      {
        notebook.authors.length > 3 && (
          <span class="text-xs text-slate-500">
            +{notebook.authors.length - 3}
          </span>
        )
      }
    </div>
    {
      notebook.date && (
        <span class="text-xs text-slate-400">{notebook.date}</span>
      )
    }
  </div>
  {
    notebook.tags && notebook.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-4">
        {notebook.tags.map((tag) => (
          <span class="px-2 py-1 text-xs bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )
  }
</a>
