---
import { withBase } from "@/config";

interface Author {
  github: string;
}

interface NotebookEntry {
  slug: string;
  path: string;
  title: string;
  description?: string;
  date?: string;
  authors: Author[];
  tags?: string[];
}

interface Props {
  notebook: NotebookEntry;
}

const { notebook } = Astro.props;
---

<a
  href={withBase(`/notebook/${notebook.slug}`)}
  class="block p-6 bg-surface-elevated rounded-xl border border-subtle hover:border-accent hover:shadow-lg transition-all"
>
  <h3 class="text-lg font-semibold text-primary mb-2">
    {notebook.title}
  </h3>
  {
    notebook.description && (
      <p class="text-secondary text-sm mb-4">
        {notebook.description}
      </p>
    )
  }
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      {
        notebook.authors.slice(0, 3).map((author) => (
          <img
            src={`https://github.com/${author.github}.png?size=40`}
            alt={author.github}
            class="w-6 h-6 rounded-full border border-subtle"
            onerror={`this.onerror=null;this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(author.github)}&size=40&background=6366f1&color=fff&bold=true';`}
          />
        ))
      }
      {
        notebook.authors.length > 3 && (
          <span class="text-xs text-muted">
            +{notebook.authors.length - 3}
          </span>
        )
      }
    </div>
    {
      notebook.date && (
        <span class="text-xs text-muted">{notebook.date}</span>
      )
    }
  </div>
  {
    notebook.tags && notebook.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-4">
        {notebook.tags.map((tag) => (
          <span class="px-2 py-1 text-xs bg-surface-elevated text-secondary rounded-full border border-subtle">
            {tag}
          </span>
        ))}
      </div>
    )
  }
</a>
