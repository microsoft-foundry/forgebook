---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { extractMarkdown } from "@/lib/notebook";

export async function getStaticPaths() {
  const notebooks = await getCollection("notebooks");
  return notebooks.map((notebook) => ({
    params: { slug: notebook.data.slug },
    props: { notebook },
  }));
}

const { notebook } = Astro.props;
const markdown = extractMarkdown(notebook.data.notebook);
---

<BaseLayout title={`${notebook.data.title} (Markdown)`}>
  <article class="max-w-4xl mx-auto">
    <header class="mb-8">
      <a
        href={`/notebook/${notebook.data.slug}`}
        class="text-blue-600 dark:text-blue-400 hover:underline text-sm mb-4 inline-block"
      >
        ← Back to notebook
      </a>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">
        {notebook.data.title}
      </h1>
      <p class="text-slate-500 mt-2">Markdown view</p>
    </header>

    <section
      class="bg-slate-50 dark:bg-slate-800 rounded-xl p-6 overflow-x-auto"
    >
      <pre
        class="text-sm text-slate-800 dark:text-slate-200 whitespace-pre-wrap font-mono">{markdown}</pre>
    </section>
  </article>
</BaseLayout>
