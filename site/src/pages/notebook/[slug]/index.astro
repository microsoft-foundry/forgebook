---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AuthorCard from "@/components/AuthorCard.astro";
import NotebookActions from "@/components/NotebookActions.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import { getCollection } from "astro:content";
import { renderNotebook } from "@/lib/notebook";
import { resolveAuthors } from "@/lib/registry";

export async function getStaticPaths() {
  const notebooks = await getCollection("notebooks");
  return notebooks.map((notebook) => ({
    params: { slug: notebook.data.slug },
    props: { notebook },
  }));
}

const { notebook } = Astro.props;
const renderedHtml = renderNotebook(notebook.data.notebook);
const authors = await resolveAuthors(notebook.data.authors);

function tagColor(tag: string): string {
  const hash = [...tag].reduce((h, c) => ((h << 5) - h + c.charCodeAt(0)) | 0, 0);
  return `tag-color-${((hash % 8) + 8) % 8}`;
}
---

<BaseLayout title={notebook.data.title} description={notebook.data.description}>
  <!-- Header -->
  <header class="max-w-4xl mx-auto mb-8 lg:max-w-none lg:pr-[252px]">
    <div class="lg:max-w-4xl">
      <h1 data-pagefind-meta="title" class="text-3xl font-bold text-primary mb-4">
        {notebook.data.title}
      </h1>
      {notebook.data.description && <meta data-pagefind-meta={`description:${notebook.data.description}`} />}

      <NotebookActions notebookPath={notebook.data.path} slug={notebook.data.slug} title={notebook.data.title} />
    </div>
  </header>

  <!-- Authors (full-bleed for more cards) -->
  <section class="max-w-5xl mx-auto mb-8 lg:max-w-none lg:pr-[252px]">
    <div class="lg:max-w-5xl">
      <h2 class="text-sm font-medium text-muted uppercase tracking-wide mb-3">
        {authors.length === 1 ? "Author" : "Authors"}
      </h2>
      <div class="flex flex-wrap gap-2">
        {authors.map((author) => <AuthorCard {...author} />)}
      </div>
    </div>
  </section>

  <!-- Main content with TOC -->
  <div class="flex justify-center">
    <article class="max-w-4xl w-full">
      <!-- Notebook Content -->
      <section class="prose prose-slate dark:prose-invert max-w-none">
        <div class="notebook-content" set:html={renderedHtml} />
      </section>

      <!-- Tags -->
      {
        notebook.data.tags && notebook.data.tags.length > 0 && (
          <section class="mt-12 pt-8 border-t border-subtle">
            <h2 class="text-sm font-medium text-muted uppercase tracking-wide mb-3">
              Tags
            </h2>
            <div class="flex flex-wrap gap-2">
              {notebook.data.tags.map((tag) => (
                  <span class={`px-3 py-1 text-sm rounded-full border font-medium ${tagColor(tag)}`}>
                    {tag}
                  </span>
                ))}
            </div>
          </section>
        )
      }
    </article>
    
    <TableOfContents />
  </div>
</BaseLayout>

<style is:global>
  .notebook-content pre {
    background-color: rgb(15 23 42);
    color: rgb(241 245 249);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.875rem;
    margin: 1rem 0;
  }

  .notebook-content .code-block-wrapper pre {
    padding-right: 3.5rem;
  }

  .notebook-content .copy-btn {
    right: 0.5rem;
  }

  .notebook-content img {
    max-width: 100%;
    height: auto;
  }

  .notebook-content iframe,
  .notebook-content video {
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
  }

  .notebook-content code {
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas,
      "Liberation Mono", monospace;
  }

  .notebook-content h1,
  .notebook-content h2,
  .notebook-content h3 {
    font-weight: 700;
    color: var(--neutral-fg-1);
  }

  .notebook-content h1 {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .notebook-content h2 {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .notebook-content h3 {
    font-size: 1.125rem;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .notebook-content p {
    margin: 1rem 0;
    color: var(--neutral-fg-2);
  }

  @media (max-width: 640px) {
    .notebook-content .code-block-wrapper pre {
      padding-right: 3.25rem;
    }
  }
</style>
