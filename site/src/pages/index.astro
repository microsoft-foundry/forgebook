---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NotebookCard from "@/components/NotebookCard.astro";
import Logo from "@/components/Logo.astro";
import { getCollection } from "astro:content";
import { absoluteSiteUrl, REPO_URL, SITE } from "@/config";
import { buildHomeSchema } from "@/lib/schema";
import popularRaw from "@/data/popular.json";

interface PopularData {
  metricVersion: "recipe-page-views-v1";
  updatedAt: string;
  since: string;
  rankingWindowDays: number;
  notebooks: { slug: string; views: number; recentViews: number }[];
}
const popularData = popularRaw as PopularData;
const viewsBySlug = new Map(popularData.notebooks.map((popular) => [popular.slug, popular.views]));

const notebooksCollection = await getCollection("notebooks");

// Transform to the format expected by NotebookCard
const notebooks = notebooksCollection.map((entry) => ({
  slug: entry.data.slug,
  path: entry.data.path,
  title: entry.data.title,
  description: entry.data.description,
  date: entry.data.date,
  authors: entry.data.authors,
  tags: entry.data.tags,
}));

// Build the "Popular" carousel from analytics-backed entries only.
type NotebookSummary = (typeof notebooks)[number];
type PopularNotebook = NotebookSummary & { viewCount: number };
const notebookBySlug = new Map(notebooks.map((n) => [n.slug, n]));
const popularNotebooks = [...popularData.notebooks]
  .sort((a, b) => b.recentViews - a.recentViews)
  .slice(0, 6)
  .map((popular) => {
    const notebook = notebookBySlug.get(popular.slug);
    if (!notebook) return undefined;

    return { ...notebook, viewCount: popular.views };
  })
  .filter((notebook): notebook is PopularNotebook => Boolean(notebook));

// Collect tags actually used by current notebooks, preserving order
const usedTagsSet = new Set<string>();
for (const n of notebooks) {
  for (const t of n.tags ?? []) usedTagsSet.add(t);
}
const usedTags = [...usedTagsSet].sort((a, b) => a.localeCompare(b));
const homeSchema = buildHomeSchema({
  canonicalUrl: absoluteSiteUrl("/", Astro.site!),
  siteUrl: absoluteSiteUrl("/", Astro.site!),
  socialImageUrl: absoluteSiteUrl(SITE.socialImage.path, Astro.site!),
});

---

<BaseLayout title={SITE.defaultTitle} description={SITE.description} canonicalPath="/" structuredData={homeSchema}>
  <div class="space-y-8" data-pagefind-ignore>
    <section class="text-center py-12">
      <h1 class="text-4xl font-bold text-primary mb-4 flex items-center justify-center gap-3">
        <Logo size={48} />
        {SITE.name}
      </h1>
      <p class="text-xl text-secondary max-w-2xl mx-auto">
        {SITE.tagline}
      </p>
    </section>

    <section class="recipe-listings">
      {popularNotebooks.length > 0 && notebooks.length >= 12 && (
        <section class="popular-section" id="popular-section" role="region" aria-labelledby="popular-heading">
          <div class="popular-section-header">
            <h2 id="popular-heading" class="text-2xl font-semibold text-primary flex items-center gap-2">
              <svg class="w-5 h-5 text-amber-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
              Popular
            </h2>
          </div>
          <div class="popular-carousel-shell">
            <div class="popular-carousel" role="list" tabindex="0" aria-label="Most Popular recipes">
            {popularNotebooks.map((notebook) => (
              <div class="popular-card-wrapper" role="listitem">
                <NotebookCard notebook={notebook} viewCount={notebook.viewCount} />
              </div>
            ))}
            </div>
          </div>
        </section>
      )}

      <section class="all-recipes-section" aria-labelledby="all-recipes-heading">
        <div class="recipes-heading-row">
          <div class="recipes-heading-title">
            <h2 id="all-recipes-heading" class="text-2xl font-semibold text-primary">
              All <span id="recipe-count" class="recipe-count text-secondary font-normal">({notebooks.length})</span>
            </h2>
          </div>

          <div class="catalog-controls">
            <div class="sort-controls" aria-label="Sort recipes">
              <div class="sort-field-toggle" role="group" aria-label="Sort field">
                <button class="icon-control sort-toggle-btn active" type="button" data-label="Date" data-sort-field="date" aria-pressed="true" aria-label="Sort by date">
                  <svg viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M6 2.25a.75.75 0 0 1 .75.75v.75h6.5V3a.75.75 0 0 1 1.5 0v.75h.75A2.5 2.5 0 0 1 18 6.25v8.25A2.5 2.5 0 0 1 15.5 17h-11A2.5 2.5 0 0 1 2 14.5V6.25a2.5 2.5 0 0 1 2.5-2.5h.75V3A.75.75 0 0 1 6 2.25ZM3.5 8v6.5c0 .55.45 1 1 1h11c.55 0 1-.45 1-1V8h-13Zm1-2.75c-.55 0-1 .45-1 1v.25h13v-.25c0-.55-.45-1-1-1h-11Z" fill="currentColor" />
                  </svg>
                  <span class="sr-only">Date</span>
                </button>
                <button class="icon-control sort-toggle-btn" type="button" data-label="Views" data-sort-field="views" aria-pressed="false" aria-label="Sort by views">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 5.25c5.1 0 8.3 4.25 9.36 6.04a1.4 1.4 0 0 1 0 1.42c-1.06 1.79-4.26 6.04-9.36 6.04s-8.3-4.25-9.36-6.04a1.4 1.4 0 0 1 0-1.42c1.06-1.79 4.26-6.04 9.36-6.04Zm0 2c-4 0-6.67 3.2-7.64 4.75.97 1.55 3.64 4.75 7.64 4.75s6.67-3.2 7.64-4.75C18.67 10.45 16 7.25 12 7.25Zm0 1.5a3.25 3.25 0 1 1 0 6.5 3.25 3.25 0 0 1 0-6.5Zm0 2a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5Z" fill="currentColor" />
                  </svg>
                  <span class="sr-only">Views</span>
                </button>
              </div>
              <button class="icon-control sort-direction-btn" type="button" data-label="Date desc" data-sort-direction="desc" aria-label="Sort date descending">
                <svg viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M5.22 11.28a.75.75 0 0 1 1.06-1.06l2.97 2.97V3.75a.75.75 0 0 1 1.5 0v9.44l2.97-2.97a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0l-4.25-4.25Z" fill="currentColor" />
                </svg>
                <span class="sr-only">Descending</span>
              </button>
            </div>

            {usedTags.length > 0 && (
              <div class="tag-filter-controls" data-tag-filter-controls>
                <details class="tag-filter-dropdown">
                  <summary class="icon-control tag-filter-summary" data-label="Filter" aria-label="Filter tags">
                    <svg viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M3.25 4A1.25 1.25 0 0 1 4.5 2.75h11A1.25 1.25 0 0 1 16.46 4.8L12 10.15v4.25c0 .42-.21.82-.56 1.05l-2 1.33A.75.75 0 0 1 8.25 16.16v-6.01L3.54 4.8A1.25 1.25 0 0 1 3.25 4Zm1.55.25 4.78 5.43c.11.14.17.31.17.5v4.58l.75-.5v-4.08c0-.19.06-.36.18-.5l4.52-5.43H4.8Z" fill="currentColor" />
                    </svg>
                    <span class="sr-only">Filter tags</span>
                    <span class="tag-filter-summary-count" data-tag-summary></span>
                  </summary>
                  <div class="tag-filter-menu" role="group" aria-label="Filter by tag">
                    <div class="tag-filter-menu-header">
                      <div>
                        <p class="tag-filter-menu-title">Tags</p>
                        <p class="tag-filter-menu-status" data-tag-status>No tags selected</p>
                      </div>
                      <button class="tag-filter-reset hidden" type="button" data-tag-mobile-clear>Clear</button>
                    </div>
                    {usedTags.map((tag) => (
                      <label class="tag-filter-option">
                        <input type="checkbox" value={tag} data-tag-checkbox />
                        <span>{tag}</span>
                      </label>
                    ))}
                  </div>
                </details>
                <button class="icon-control tag-filter-inline-clear hidden" type="button" data-label="Clear filter" data-tag-inline-clear aria-label="Clear tag filters">
                  <svg viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M5.22 5.22a.75.75 0 0 1 1.06 0L10 8.94l3.72-3.72a.75.75 0 1 1 1.06 1.06L11.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06L10 11.06l-3.72 3.72a.75.75 0 0 1-1.06-1.06L8.94 10 5.22 6.28a.75.75 0 0 1 0-1.06Z" fill="currentColor" />
                  </svg>
                  <span class="sr-only">Clear tag filters</span>
                </button>
              </div>
            )}

            <div class="view-toggle" role="group" aria-label="Recipe layout">
              <button class="icon-control view-toggle-btn active" type="button" data-label="Grid" data-recipe-view="grid" aria-pressed="true" aria-label="Grid view">
                <svg viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M3 3.5A1.5 1.5 0 0 1 4.5 2h3A1.5 1.5 0 0 1 9 3.5v3A1.5 1.5 0 0 1 7.5 8h-3A1.5 1.5 0 0 1 3 6.5v-3Zm8 0A1.5 1.5 0 0 1 12.5 2h3A1.5 1.5 0 0 1 17 3.5v3A1.5 1.5 0 0 1 15.5 8h-3A1.5 1.5 0 0 1 11 6.5v-3Zm-8 10A1.5 1.5 0 0 1 4.5 12h3A1.5 1.5 0 0 1 9 13.5v3A1.5 1.5 0 0 1 7.5 18h-3A1.5 1.5 0 0 1 3 16.5v-3Zm8 0a1.5 1.5 0 0 1 1.5-1.5h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3a1.5 1.5 0 0 1-1.5-1.5v-3Z" fill="currentColor" />
                </svg>
                <span class="sr-only">Grid view</span>
              </button>
              <button class="icon-control view-toggle-btn" type="button" data-label="List" data-recipe-view="list" aria-pressed="false" aria-label="List view">
                <svg viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M4 4.75A1.25 1.25 0 1 1 1.5 4.75 1.25 1.25 0 0 1 4 4.75Zm2.25-.75h11a.75.75 0 0 1 0 1.5h-11a.75.75 0 0 1 0-1.5ZM4 10a1.25 1.25 0 1 1-2.5 0A1.25 1.25 0 0 1 4 10Zm2.25-.75h11a.75.75 0 0 1 0 1.5h-11a.75.75 0 0 1 0-1.5ZM4 15.25a1.25 1.25 0 1 1-2.5 0 1.25 1.25 0 0 1 2.5 0Zm2.25-.75h11a.75.75 0 0 1 0 1.5h-11a.75.75 0 0 1 0-1.5Z" fill="currentColor" />
                </svg>
                <span class="sr-only">List view</span>
              </button>
            </div>
          </div>
        </div>

        <div class="notebooks-collection grid-view" id="notebooks-grid" data-view="grid">
          {notebooks.map((notebook) => (
            <div
              class="notebook-card-wrapper h-full"
              data-date={notebook.date ?? ""}
              data-tags={(notebook.tags ?? []).join(",")}
              data-title={notebook.title}
              data-views={viewsBySlug.get(notebook.slug) ?? 0}
            >
              <NotebookCard notebook={notebook} />
            </div>
          ))}
        </div>
      </section>

      {
        notebooks.length === 0 && (
          <div class="text-center py-12 text-muted">
            <p>No notebooks published yet.</p>
            <p class="text-sm mt-2">
              Add notebooks to{" "}
              <code class="bg-surface-elevated px-2 py-1 rounded border border-subtle">
                registry.yaml
              </code>{" "}
              to get started.
            </p>
          </div>
        )
      }
    </section>

    <section class="mt-12">
      <h2
        class="text-2xl font-semibold text-primary mb-4"
      >
        Start forging
      </h2>
      <pre
        class="bg-code text-code p-4 rounded-lg overflow-x-auto text-sm font-mono"><code>{`git clone ${REPO_URL}.git
cd forgebook
pip install -r requirements.txt
jupyter notebook`}</code></pre>
    </section>
  </div>
</BaseLayout>

<style>
  .recipe-listings {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .section-eyebrow {
    color: var(--neutral-fg-3);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
  }

  .popular-section {
    border-bottom: 1px solid var(--neutral-bg-4);
    padding-bottom: 2rem;
  }

  .popular-section-header,
  .recipes-heading-row {
    align-items: end;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .popular-section-header {
    margin-bottom: 1rem;
  }

  .popular-carousel-shell {
    --popular-card-width: 22rem;
    position: relative;
  }

  .popular-carousel-shell::after {
    background: linear-gradient(90deg, transparent, var(--neutral-bg-1));
    bottom: 0.75rem;
    content: "";
    pointer-events: none;
    position: absolute;
    right: 0;
    top: 0;
    width: 3rem;
  }

  .popular-carousel {
    display: flex;
    gap: 1rem;
    margin-inline: -0.25rem;
    overflow-x: auto;
    padding: 0.25rem 3rem 1.25rem 0.25rem;
    scroll-padding-inline: 0.25rem;
    scroll-snap-type: x mandatory;
    scrollbar-color: color-mix(in srgb, var(--accent-brand) 38%, var(--neutral-bg-4)) transparent;
    scrollbar-width: thin;
  }

  .popular-carousel::-webkit-scrollbar {
    height: 0.55rem;
  }

  .popular-carousel::-webkit-scrollbar-track {
    background: transparent;
  }

  .popular-carousel::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--accent-brand) 38%, var(--neutral-bg-4));
    border: 2px solid var(--neutral-bg-1);
    border-radius: 9999px;
  }

  .popular-carousel::-webkit-scrollbar-thumb:hover {
    background: color-mix(in srgb, var(--accent-brand) 55%, var(--neutral-bg-4));
  }

  .popular-carousel:focus-visible {
    border-radius: 1rem;
  }

  .popular-card-wrapper {
    display: flex;
    flex: 0 0 var(--popular-card-width);
    max-width: var(--popular-card-width);
    min-width: var(--popular-card-width);
    scroll-snap-align: start;
    width: var(--popular-card-width);
  }

  .popular-card-wrapper :global(.notebook-card) {
    min-width: 0;
    width: 100%;
  }

  .popular-card-wrapper :global(.notebook-card-description) {
    min-height: 4.5rem;
  }

  .all-recipes-section {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .catalog-controls {
    align-items: center;
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    justify-content: flex-end;
    min-height: 2.5rem;
  }

  .recipes-heading-title {
    flex: 0 0 auto;
  }

  .recipes-heading-title h2 {
    text-wrap: balance;
    white-space: nowrap;
  }

  .icon-control {
    position: relative;
  }

  .icon-control::after {
    background: var(--neutral-fg-1);
    border-radius: 0.4rem;
    bottom: calc(100% + 0.45rem);
    color: var(--neutral-bg-1);
    content: attr(data-label);
    font-size: 0.72rem;
    font-weight: 600;
    left: 50%;
    line-height: 1;
    opacity: 0;
    padding: 0.35rem 0.45rem;
    pointer-events: none;
    position: absolute;
    transform: translate(-50%, 0.2rem);
    transition: opacity 0.15s ease, transform 0.15s ease;
    white-space: nowrap;
    z-index: 30;
  }

  .icon-control:hover::after,
  .icon-control:focus-visible::after {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  .sort-controls {
    align-items: center;
    background: var(--neutral-bg-3);
    border: 1px solid var(--neutral-bg-4);
    border-radius: 9999px;
    box-shadow: 0 1px 2px color-mix(in srgb, #000000 7%, transparent);
    box-sizing: border-box;
    display: inline-flex;
    gap: 0;
    height: 2.5rem;
    padding: 0.25rem;
  }

  .sort-field-toggle {
    align-items: center;
    display: inline-flex;
    gap: 0.25rem;
  }

  .sort-toggle-btn,
  .sort-direction-btn {
    align-items: center;
    border-radius: 9999px;
    box-sizing: border-box;
    color: var(--neutral-fg-2);
    cursor: pointer;
    display: inline-flex;
    height: 2rem;
    justify-content: center;
    min-width: 2rem;
    padding: 0;
    transition: background-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    width: 2rem;
  }

  .sort-toggle-btn svg,
  .sort-direction-btn svg {
    height: 1rem;
    width: 1rem;
  }

  .sort-toggle-btn.active {
    background: var(--accent-brand);
    box-shadow: 0 1px 2px color-mix(in srgb, #000000 12%, transparent);
    color: #fff;
  }

  .sort-direction-btn {
    background: var(--neutral-bg-1);
    border-left: 1px solid var(--neutral-bg-4);
    border-radius: 0 9999px 9999px 0;
    margin-left: 0.15rem;
    padding-left: 0.3rem;
    width: 2.2rem;
  }

  .sort-direction-btn::before {
    background: var(--accent-brand);
    border-radius: 9999px;
    bottom: 0.4rem;
    content: "";
    left: 0.2rem;
    position: absolute;
    top: 0.4rem;
    width: 2px;
  }

  .sort-direction-btn[data-sort-direction="asc"] svg {
    transform: rotate(180deg);
  }

  .sort-toggle-btn:not(.active):hover,
  .sort-toggle-btn:not(.active):focus-visible,
  .sort-direction-btn:hover,
  .sort-direction-btn:focus-visible {
    background-color: var(--neutral-bg-1);
    color: var(--neutral-fg-1);
  }

  .view-toggle {
    align-items: center;
    background: var(--neutral-bg-3);
    border: 1px solid var(--neutral-bg-4);
    border-radius: 9999px;
    box-shadow: 0 1px 2px color-mix(in srgb, #000000 7%, transparent);
    box-sizing: border-box;
    display: inline-flex;
    height: 2.5rem;
    gap: 0.25rem;
    padding: 0.25rem;
  }

  .view-toggle-btn {
    align-items: center;
    border-radius: 9999px;
    box-sizing: border-box;
    color: var(--neutral-fg-2);
    cursor: pointer;
    display: inline-flex;
    font-size: 0.8125rem;
    font-weight: 600;
    height: 2rem;
    justify-content: center;
    min-height: 2rem;
    min-width: 2rem;
    padding: 0;
    transition: background-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
    width: 2rem;
  }

  .view-toggle-btn svg {
    height: 1rem;
    width: 1rem;
  }

  .view-toggle-btn.active {
    background: var(--accent-brand);
    box-shadow: 0 1px 2px color-mix(in srgb, #000000 12%, transparent);
    color: #fff;
  }

  .view-toggle-btn:not(.active):hover,
  .view-toggle-btn:not(.active):focus-visible {
    background-color: var(--neutral-bg-1);
    color: var(--neutral-fg-1);
  }

  .notebooks-collection.grid-view {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 22rem));
    justify-content: center;
  }

  .notebooks-collection.list-view {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .notebooks-collection.list-view .notebook-card-wrapper {
    height: auto;
  }

  .notebooks-collection.list-view :global(.notebook-card) {
    align-items: center;
    flex-direction: row;
    gap: 1.25rem;
    padding: 0.95rem 1.1rem;
  }

  .notebooks-collection.list-view :global(.notebook-card-main) {
    flex: 1 1 auto;
    min-width: 0;
  }

  .notebooks-collection.list-view :global(.notebook-card-title) {
    display: block;
    font-size: 0.95rem;
    line-height: 1.35;
    margin-bottom: 0.35rem;
    min-height: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .notebooks-collection.list-view :global(.notebook-card-description) {
    display: none;
  }

  .notebooks-collection.list-view :global(.notebook-card-footer) {
    align-items: center;
    display: grid;
    flex: 0 0 clamp(16rem, 34vw, 24rem);
    gap: 0.75rem;
    grid-template-columns: 6rem minmax(0, 1fr);
    margin-top: 0;
    min-width: 0;
  }

  .notebooks-collection.list-view :global(.notebook-card-authors) {
    display: none;
  }

  .notebooks-collection.list-view :global(.notebook-card-meta) {
    display: block;
    justify-self: start;
  }

  .notebooks-collection.list-view :global(.notebook-tags-row) {
    justify-self: end;
    margin-top: 0;
    max-width: 100%;
  }

  .notebooks-collection.list-view :global(.notebook-tags-row [data-tag-chip]:nth-of-type(n + 3)) {
    display: none !important;
  }

  .tag-filter-bar {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .tag-filter-bar::-webkit-scrollbar {
    display: none;
  }

  .tag-filter-btn {
    flex-shrink: 0;
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 9999px;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }
  /* "All" button and default (non-colored) style */
  .tag-filter-btn:not([class*="tag-color-"]) {
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-elevated);
    color: var(--color-text-secondary);
  }
  /* Colored tag buttons use global .tag-color-N styles; just add border */
  .tag-filter-btn[class*="tag-color-"] {
    border: 1px solid transparent;
  }
  .tag-filter-btn:hover {
