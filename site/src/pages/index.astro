---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NotebookCard from "@/components/NotebookCard.astro";
import Logo from "@/components/Logo.astro";
import { getCollection } from "astro:content";
import { REPO_URL } from "@/config";
import popularRaw from "@/data/popular.json";

interface PopularData {
  updatedAt: string;
  notebooks: { slug: string; views: number }[];
}
const popularData = popularRaw as PopularData;

const notebooksCollection = await getCollection("notebooks");

// Transform to the format expected by NotebookCard
const notebooks = notebooksCollection.map((entry) => ({
  slug: entry.data.slug,
  path: entry.data.path,
  title: entry.data.title,
  description: entry.data.description,
  date: entry.data.date,
  authors: entry.data.authors,
  tags: entry.data.tags,
}));

// Build the "Most Popular" list by matching popular slugs to notebook data
const popularSlugs = new Set(popularData.notebooks.map((n) => n.slug));
const popularNotebooks = notebooks.filter((n) => popularSlugs.has(n.slug));

// Collect tags actually used by current notebooks, preserving order
const usedTagsSet = new Set<string>();
for (const n of notebooks) {
  for (const t of n.tags ?? []) usedTagsSet.add(t);
}
const usedTags = [...usedTagsSet];

function tagColor(tag: string): string {
  const hash = [...tag].reduce((h, c) => ((h << 5) - h + c.charCodeAt(0)) | 0, 0);
  return `tag-color-${((hash % 8) + 8) % 8}`;
}
---

<BaseLayout title="Home">
  <div class="space-y-8" data-pagefind-ignore>
    <section class="text-center py-12">
      <h1 class="text-4xl font-bold text-primary mb-4 flex items-center justify-center gap-3">
        <Logo size={48} />
        Forgebook
      </h1>
      <p class="text-xl text-secondary max-w-2xl mx-auto">
        Your cookbook for building AI in Foundry.
      </p>
    </section>

    <section>
      <h2 class="text-2xl font-semibold text-primary mb-4">
        Recipes
      </h2>

      {usedTags.length > 0 && (
        <div class="tag-filter-bar mb-6" role="toolbar" aria-label="Filter by tag">
          {usedTags.map((tag) => (
            <button
              class={`tag-filter-btn ${tagColor(tag)}`}
              data-tag={tag}
              type="button"
            >{tag}</button>
          ))}
          <button
            class="tag-filter-btn tag-clear-btn hidden"
            data-tag="clear"
            type="button"
            aria-label="Clear filter"
          >✕</button>
        </div>
      )}

      {popularNotebooks.length > 0 && (
        <div class="mb-10" id="popular-section">
          <h3 class="text-lg font-medium text-secondary mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            Most Popular
          </h3>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {popularNotebooks.map((notebook) => (
              <div class="notebook-card-wrapper" data-tags={(notebook.tags ?? []).join(",")}>
                <NotebookCard notebook={notebook} />
              </div>
            ))}
          </div>
        </div>
      )}

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="notebooks-grid">
        {notebooks.map((notebook) => (
          <div class="notebook-card-wrapper" data-tags={(notebook.tags ?? []).join(",")}>
            <NotebookCard notebook={notebook} />
          </div>
        ))}
      </div>

      {
        notebooks.length === 0 && (
          <div class="text-center py-12 text-muted">
            <p>No notebooks published yet.</p>
            <p class="text-sm mt-2">
              Add notebooks to{" "}
              <code class="bg-surface-elevated px-2 py-1 rounded border border-subtle">
                registry.yaml
              </code>{" "}
              to get started.
            </p>
          </div>
        )
      }
    </section>

    <section class="bg-surface-elevated rounded-xl p-8 mt-12 border border-subtle">
      <h2
        class="text-xl font-semibold text-primary mb-4"
      >
        Quick Start
      </h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-medium text-secondary mb-2">
            Clone and run locally:
          </h3>
          <pre
            class="bg-code text-code p-4 rounded-lg overflow-x-auto text-sm font-mono"><code>{`git clone ${REPO_URL}.git
cd forgebook
pip install -r requirements.txt
jupyter notebook`}</code></pre>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .tag-filter-bar {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .tag-filter-bar::-webkit-scrollbar {
    display: none;
  }

  .tag-filter-btn {
    flex-shrink: 0;
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 9999px;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }
  /* "All" button and default (non-colored) style */
  .tag-filter-btn:not([class*="tag-color-"]) {
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-elevated);
    color: var(--color-text-secondary);
  }
  /* Colored tag buttons use global .tag-color-N styles; just add border */
  .tag-filter-btn[class*="tag-color-"] {
    border: 1px solid transparent;
  }
  .tag-filter-btn:hover {
    opacity: 0.85;
  }
  .tag-filter-btn:not([class*="tag-color-"]):hover {
    border-color: var(--color-border-accent);
  }
  .tag-filter-btn.active:not([class*="tag-color-"]) {
    border-color: var(--color-border-accent);
    background: var(--color-surface-accent, var(--color-border-accent));
    color: var(--color-text-on-accent, #fff);
  }
  /* Colored tag buttons get a stronger ring when active */
  .tag-filter-btn[class*="tag-color-"].active {
    outline: 3px solid currentColor;
    outline-offset: 2px;
    opacity: 1;
    transform: scale(1.08);
    box-shadow: 0 0 12px 2px currentColor;
  }
  .tag-filter-btn[class*="tag-color-"]:not(.active) {
    opacity: 0.5;
  }
  .tag-clear-btn {
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-elevated);
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    padding: 0.375rem 0.625rem;
    opacity: 1;
  }
  .tag-clear-btn:hover {
    border-color: var(--color-border-accent);
    color: var(--color-text-primary);
  }
  .tag-clear-btn.hidden {
    display: none;
  }

  /* Desktop: allow wrapping */
  @media (min-width: 640px) {
    .tag-filter-bar {
      flex-wrap: wrap;
      overflow-x: visible;
    }
  }

  .notebook-card-wrapper {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .notebook-card-wrapper.hidden {
    display: none;
  }
</style>

<script>
  function initTagFilter() {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-filter-btn:not(.tag-clear-btn)");
    const clearBtn = document.querySelector<HTMLButtonElement>(".tag-clear-btn");
    const cards = document.querySelectorAll<HTMLElement>(".notebook-card-wrapper");
    const popularSection = document.getElementById("popular-section");

    if (!buttons.length) return;

    const activeTags = new Set<string>();

    function applyFilter() {
      buttons.forEach((btn) => {
        btn.classList.toggle("active", activeTags.has(btn.dataset.tag!));
      });

      if (clearBtn) clearBtn.classList.toggle("hidden", activeTags.size === 0);

      let visiblePopular = 0;
      cards.forEach((card) => {
        const cardTags = (card.dataset.tags ?? "").split(",");
        const show = activeTags.size === 0 || cardTags.some((t) => activeTags.has(t));
        card.classList.toggle("hidden", !show);
        if (show && popularSection?.contains(card)) visiblePopular++;
      });

      if (popularSection) {
        popularSection.classList.toggle("hidden", activeTags.size > 0 && visiblePopular === 0);
      }

      const hashVal = [...activeTags].join("+");
      history.replaceState(null, "", hashVal ? `#tag=${hashVal}` : location.pathname);
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tag = btn.dataset.tag!;
        if (activeTags.has(tag)) {
          activeTags.delete(tag);
        } else {
          activeTags.add(tag);
        }
        applyFilter();
      });
    });

    if (clearBtn) {
      clearBtn.addEventListener("click", () => {
        activeTags.clear();
        applyFilter();
      });
    }

    // Restore from URL hash
    const hash = location.hash;
    if (hash.startsWith("#tag=")) {
      for (const t of decodeURIComponent(hash.slice(5)).split("+")) {
        if (t) activeTags.add(t);
      }
      applyFilter();
    }
  }

  initTagFilter();
  document.addEventListener("astro:after-swap", initTagFilter);
</script>
