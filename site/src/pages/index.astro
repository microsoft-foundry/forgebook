</style>

<script>
  import { trackEvent } from "@/lib/telemetry";

  const recipeViewStorageKey = "forgebook-recipe-view";
  type RecipeView = "grid" | "list";
  type RecipeSortField = "date" | "views";
  type RecipeSortDirection = "asc" | "desc";

  function refitNotebookCards() {
    document.dispatchEvent(new Event("forgebook:cards-resized"));
  }

  function initRecipeViewToggle() {
    const grid = document.getElementById("notebooks-grid");
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-recipe-view]");
    if (!grid || !buttons.length || grid.dataset.viewToggleInitialized === "true") return;

    const collection = grid;
    collection.dataset.viewToggleInitialized = "true";

    function setView(view: RecipeView, persist = false) {
      collection.classList.toggle("grid-view", view === "grid");
      collection.classList.toggle("list-view", view === "list");
      collection.dataset.view = view;

      buttons.forEach((button) => {
        const isActive = button.dataset.recipeView === view;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });

      if (persist) {
        localStorage.setItem(recipeViewStorageKey, view);
        trackEvent("RecipeViewToggle", { view });
      }

      refitNotebookCards();
    }

    const storedView = localStorage.getItem(recipeViewStorageKey);
    setView(storedView === "list" ? "list" : "grid");

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const view = button.dataset.recipeView === "list" ? "list" : "grid";
        setView(view, true);
      });
    });
  }

  function initRecipeSorting() {
    const collection = document.getElementById("notebooks-grid");
    const fieldButtons = document.querySelectorAll<HTMLButtonElement>("[data-sort-field]");
    const directionButton = document.querySelector<HTMLButtonElement>("[data-sort-direction]");
    if (!collection || !fieldButtons.length || !directionButton || collection.dataset.sortInitialized === "true") return;

    const recipeCollection = collection;
    const sortDirectionButton = directionButton;
    recipeCollection.dataset.sortInitialized = "true";
    let sortField: RecipeSortField = "date";
    let sortDirection: RecipeSortDirection = "desc";

    function getDateValue(card: HTMLElement) {
      const date = card.dataset.date ?? "";
      const parsed = Date.parse(date);
      return Number.isNaN(parsed) ? 0 : parsed;
    }

    function getViewsValue(card: HTMLElement) {
      return Number.parseInt(card.dataset.views ?? "0", 10) || 0;
    }

    function updateSortControls() {
      fieldButtons.forEach((button) => {
        const isActive = button.dataset.sortField === sortField;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });

      const fieldLabel = sortField === "views" ? "Views" : "Date";
      const directionLabel = sortDirection === "desc" ? "desc" : "asc";
      sortDirectionButton.dataset.sortDirection = sortDirection;
      sortDirectionButton.dataset.label = `${fieldLabel} ${directionLabel}`;
      sortDirectionButton.setAttribute(
        "aria-label",
        `Sort ${fieldLabel.toLowerCase()} ${sortDirection === "desc" ? "descending" : "ascending"}`,
      );
      const srText = sortDirectionButton.querySelector(".sr-only");
      if (srText) srText.textContent = `${fieldLabel} ${sortDirection === "desc" ? "descending" : "ascending"}`;
    }

    function sortCards() {
      const cards = Array.from(recipeCollection.querySelectorAll<HTMLElement>(":scope > .notebook-card-wrapper"));
      const sortedCards = cards.sort((a, b) => {
        const titleCompare = (a.dataset.title ?? "").localeCompare(b.dataset.title ?? "");

        if (sortField === "views") {
          const viewsCompare = sortDirection === "asc"
            ? getViewsValue(a) - getViewsValue(b)
            : getViewsValue(b) - getViewsValue(a);
          return viewsCompare || getDateValue(b) - getDateValue(a) || titleCompare;
        }

        const dateCompare = sortDirection === "asc"
          ? getDateValue(a) - getDateValue(b)
          : getDateValue(b) - getDateValue(a);
        return dateCompare || titleCompare;
      });

      sortedCards.forEach((card) => recipeCollection.appendChild(card));
      updateSortControls();
      refitNotebookCards();
    }

    fieldButtons.forEach((button) => {
      button.addEventListener("click", () => {
        sortField = button.dataset.sortField === "views" ? "views" : "date";
        sortCards();
        trackEvent("RecipeSort", { field: sortField, direction: sortDirection });
      });
    });

    sortDirectionButton.addEventListener("click", () => {
      sortDirection = sortDirection === "desc" ? "asc" : "desc";
      sortCards();
      trackEvent("RecipeSort", { field: sortField, direction: sortDirection });
    });

    sortCards();
  }

  function initTagFilter() {
    const collection = document.getElementById("notebooks-grid");
    if (!collection || collection.dataset.tagFilterInitialized === "true") return;

    collection.dataset.tagFilterInitialized = "true";

    const buttons = document.querySelectorAll<HTMLButtonElement>(".tag-filter-btn:not(.tag-clear-btn)");
    const checkboxes = document.querySelectorAll<HTMLInputElement>("[data-tag-checkbox]");
    const clearBtn = document.querySelector<HTMLButtonElement>(".tag-clear-btn");
    const mobileClearBtn = document.querySelector<HTMLButtonElement>("[data-tag-mobile-clear]");
    const inlineClearBtn = document.querySelector<HTMLButtonElement>("[data-tag-inline-clear]");
    const recipeCount = document.getElementById("recipe-count");
    const mainCards = document.querySelectorAll<HTMLElement>("#notebooks-grid > .notebook-card-wrapper");
    const summary = document.querySelector<HTMLElement>("[data-tag-summary]");
    const status = document.querySelector<HTMLElement>("[data-tag-status]");
    const filterBar = document.querySelector<HTMLElement>(".tag-filter-bar");
    const dropdown = document.querySelector<HTMLDetailsElement>(".tag-filter-dropdown");
    const filterControls = document.querySelector<HTMLElement>("[data-tag-filter-controls]");
    const recipesHeadingRow = document.querySelector<HTMLElement>(".recipes-heading-row");

    if (!buttons.length && !checkboxes.length) return;

    const allTags = new Set<string>();
    buttons.forEach((btn) => {
      if (btn.dataset.tag) allTags.add(btn.dataset.tag);
    });
    checkboxes.forEach((checkbox) => {
      if (checkbox.value) allTags.add(checkbox.value);
    });
    const activeTags = new Set<string>();

    function hasActiveFilter() {
      return activeTags.size > 0;
    }

    function clearTags() {
      activeTags.clear();
    }

    function updateControls() {
      const filtering = hasActiveFilter();
      buttons.forEach((btn) => {
        btn.classList.toggle("active", activeTags.has(btn.dataset.tag ?? ""));
      });
      checkboxes.forEach((checkbox) => {
        checkbox.checked = activeTags.has(checkbox.value);
      });

      if (filterBar) filterBar.classList.toggle("filtering", filtering);
      if (filterControls) filterControls.classList.toggle("filtering", filtering);
      if (recipesHeadingRow) recipesHeadingRow.classList.toggle("has-active-filter", filtering);
      if (clearBtn) clearBtn.classList.toggle("hidden", !filtering);
      if (mobileClearBtn) mobileClearBtn.classList.toggle("hidden", !filtering);
      if (inlineClearBtn) inlineClearBtn.classList.toggle("hidden", !filtering);
      if (summary) summary.textContent = filtering ? activeTags.size.toString() : "";
      if (status) status.textContent = filtering ? `${activeTags.size} selected` : "No tags selected";
    }

    function applyFilter() {
      updateControls();

      let visibleMain = 0;
      mainCards.forEach((card) => {
        const cardTags = (card.dataset.tags ?? "").split(",");
        const show = !hasActiveFilter() || cardTags.some((t) => activeTags.has(t));
        card.classList.toggle("hidden", !show);
        if (show) visibleMain++;
      });

      if (recipeCount) recipeCount.textContent = `(${visibleMain})`;

      const hashVal = hasActiveFilter() ? [...activeTags].join("+") : "";
      history.replaceState(null, "", hashVal ? `#tag=${hashVal}` : location.pathname);
      refitNotebookCards();
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tag = btn.dataset.tag;
        if (!tag) return;

        if (!hasActiveFilter()) {
          activeTags.clear();
          activeTags.add(tag);
        } else if (activeTags.has(tag)) {
          activeTags.delete(tag);
        } else {
          activeTags.add(tag);
        }
        applyFilter();
        trackEvent("TagFilter", {
          tag,
          activeTags: [...activeTags].join(","),
          isFiltering: hasActiveFilter(),
        });
      });
    });

    checkboxes.forEach((checkbox) => {
      checkbox.addEventListener("change", () => {
        activeTags.clear();
        checkboxes.forEach((box) => {
          if (box.checked) activeTags.add(box.value);
        });
        applyFilter();
        trackEvent("TagFilter", {
          tag: checkbox.value,
          activeTags: [...activeTags].join(","),
          isFiltering: hasActiveFilter(),
        });
      });
    });

    if (clearBtn) {
      clearBtn.addEventListener("click", () => {
        clearTags();
        applyFilter();
        trackEvent("TagFilter", { tag: "clear", activeTags: "all", isFiltering: false });
      });
    }

    if (mobileClearBtn) {
      mobileClearBtn.addEventListener("click", () => {
        clearTags();
        applyFilter();
        trackEvent("TagFilter", { tag: "clear", activeTags: "all", isFiltering: false });
      });
    }

    if (inlineClearBtn) {
      inlineClearBtn.addEventListener("click", () => {
        clearTags();
        if (dropdown) dropdown.open = false;
        applyFilter();
        trackEvent("TagFilter", { tag: "clear", activeTags: "all", isFiltering: false });
      });
    }

    if (dropdown) {
      document.addEventListener("click", (event) => {
        const target = event.target;
        if (target instanceof Node && dropdown.open && !dropdown.contains(target)) {
          dropdown.open = false;
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && dropdown.open) {
          dropdown.open = false;
          dropdown.querySelector<HTMLElement>("summary")?.focus();
        }
      });
    }

    const hash = location.hash;
    if (hash.startsWith("#tag=")) {
      activeTags.clear();
      for (const t of decodeURIComponent(hash.slice(5)).split("+")) {
        if (t && allTags.has(t)) activeTags.add(t);
      }
      applyFilter();
    } else {
      updateControls();
    }
  }

  initRecipeViewToggle();
  initRecipeSorting();
  initTagFilter();
  document.addEventListener("astro:after-swap", initRecipeViewToggle);
  document.addEventListener("astro:after-swap", initRecipeSorting);
  document.addEventListener("astro:after-swap", initTagFilter);
</script>
