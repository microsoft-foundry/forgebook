{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Registry Schema",
  "description": "Schema for the notebook registry.yaml file",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["slug", "path", "title", "authors"],
    "properties": {
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "description": "URL-safe identifier for the notebook"
      },
      "path": {
        "type": "string",
        "pattern": "^notebooks/.*\\.ipynb$",
        "description": "Path to the notebook file relative to repo root"
      },
      "title": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200,
        "description": "Display title for the notebook"
      },
      "description": {
        "type": "string",
        "maxLength": 500,
        "description": "Short description for previews"
      },
      "date": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
        "description": "Publication date in YYYY-MM-DD format"
      },
      "authors": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["github"],
          "properties": {
            "github": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9](?:[a-zA-Z0-9-]*[a-zA-Z0-9])?$",
              "description": "GitHub username"
            }
          }
        },
        "description": "List of authors by GitHub username"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "description": "Topic tags for categorization"
      }
    },
    "additionalProperties": false
  }
}
