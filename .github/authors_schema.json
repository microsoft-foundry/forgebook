{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Authors Schema",
  "description": "Schema for the authors.yaml file",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Display name for the author"
      },
      "title": {
        "type": "string",
        "description": "Author title or role"
      },
      "website": {
        "type": "string",
        "format": "uri",
        "description": "Author's website or social profile URL"
      },
      "avatar": {
        "type": "string",
        "format": "uri",
        "description": "URL to author's avatar image"
      },
      "githubUrl": {
        "type": "string",
        "format": "uri",
        "description": "Author's GitHub profile URL"
      },
      "linkedinUrl": {
        "type": "string",
        "format": "uri",
        "description": "Author's LinkedIn profile URL"
      },
      "xUrl": {
        "type": "string",
        "format": "uri",
        "description": "Author's X profile URL"
      }
    },
    "additionalProperties": false
  }
}
