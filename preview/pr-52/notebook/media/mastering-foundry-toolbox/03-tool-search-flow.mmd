%%{init: {"theme":"base","themeVariables":{"fontFamily":"Segoe UI, Helvetica, Arial, sans-serif","primaryColor":"#eef4ff","primaryBorderColor":"#3b6fd6","primaryTextColor":"#102a54","lineColor":"#5b6b86","clusterBkg":"#f7f9fc","clusterBorder":"#c7d2e3"}}}%%
flowchart TB
    START["Model receives a user turn"] --> LIST

    subgraph LIST["tools/list (small, flat)"]
        direction TB
        M1["tool_search (meta-tool)"]:::accent
        M2["call_tool (meta-tool)"]:::accent
        PIN["pinned + auto-pinned tools"]:::pin
    end

    LIST --> NEED{"Capability in<br/>current list?"}
    NEED -->|yes| CALL
    NEED -->|no| SEARCH["tool_search(query, limit?)"]:::accent

    subgraph RANK["Foundry ranks the toolbox's un-pinned tools"]
        direction TB
        R1["match on name + description<br/>(semantic)"]
        R2["+ additional_search_text keywords"]
        R3["+ per-user auto-pin hot set"]
    end
    SEARCH --> RANK
    RANK --> RET["returns only matching tool defs"]
    RET --> CALL["call_tool(name, args)"]:::accent

    CALL --> PERSIST["returned tools stay callable<br/>for the rest of the turn"]:::note
    PERSIST -->|new step needs other tools| SEARCH

    classDef accent fill:#dbe9ff,stroke:#3b6fd6,color:#102a54,font-weight:bold;
    classDef pin fill:#fff4e6,stroke:#e8910c,color:#5c3b00;
    classDef note fill:#f3eefc,stroke:#7d57c2,color:#33215c;
