%%{init: {"theme":"base","themeVariables":{"fontFamily":"Segoe UI, Helvetica, Arial, sans-serif","primaryColor":"#eef4ff","primaryBorderColor":"#3b6fd6","primaryTextColor":"#102a54","lineColor":"#5b6b86","clusterBkg":"#f7f9fc","clusterBorder":"#c7d2e3"}}}%%
flowchart TB
    subgraph CP["1 - Control plane (admin)"]
        direction TB
        POL["Azure Policy<br/>(authored separately)"]:::policy
        CONNCREATE["Create project connection"]:::step
        POL -->|enforced at connection-creation time| CONNCREATE
        CONNCREATE -->|banned endpoint/auth| BLOCK["create blocked"]:::block
    end

    subgraph RT["2 - Runtime gateway (customer-owned) - MCP-server tools only"]
        direction TB
        APIM["Azure API Management<br/>rate-limit &middot; IP filter &middot; header handling"]:::apim
        MCP["Your MCP server"]:::tool
        APIM --> MCP
    end
    NOTE2["Registered as a normal MCP tool:<br/>server_url = APIM gateway URL.<br/>Only calls that route through your MCP server<br/>are governed here."]:::note
    APIM -.-> NOTE2

    BUILTIN["Built-in / first-party tools<br/>(Web Search, Code Interpreter, File Search,<br/>Azure AI Search, ...) - never traverse your gateway"]:::bypass

    subgraph TB3["3 - Toolbox guardrail"]
        direction TB
        RAI["RAI policy<br/>policies.rai_config.rai_policy_name"]:::rai
        IO["screens tool inputs / outputs"]:::step
        RAI --> IO
    end

    CONNCREATE --> TBXV["Toolbox version"]:::accent
    TBXV -->|"MCP-server tools"| RT
    TBXV -->|"not MCP - no gateway"| BUILTIN
    TBXV --> TB3

    classDef accent fill:#dbe9ff,stroke:#3b6fd6,color:#102a54,font-weight:bold;
    classDef policy fill:#fff4e6,stroke:#e8910c,color:#5c3b00;
    classDef apim fill:#e9f0fb,stroke:#3b6fd6,color:#102a54;
    classDef rai fill:#eef7ee,stroke:#3a9d4a,color:#13431d;
    classDef tool fill:#f7f9fc,stroke:#5b6b86,color:#2a3550;
    classDef step fill:#ffffff,stroke:#9aa7bd,color:#2a3550;
    classDef block fill:#fde8e8,stroke:#cc3b3b,color:#5c1313,font-weight:bold;
    classDef note fill:#f3eefc,stroke:#7d57c2,color:#33215c;
    classDef bypass fill:#f7f9fc,stroke:#9aa7bd,color:#2a3550,stroke-dasharray:4 3;
